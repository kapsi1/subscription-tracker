# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=subscription_tracker
DATABASE_URL=postgresql://postgres:postgres@subtracker.local:5433/subscription_tracker?schema=public

# Redis
REDIS_HOST=subtracker.local
REDIS_PORT=6379

# Backend
PORT=3001
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRES_IN=1h

# Frontend
NEXT_PUBLIC_API_URL=http://subtracker.local:3000

# SMTP Configuration (Production defaults for Resend/Brevo)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM="SubTracker" <noreply@subtracker.cc>
SMTP_FROM_AUTH="SubTracker" <auth@subtracker.cc>
SMTP_FROM_ALERTS="SubTracker" <alerts@subtracker.cc>
