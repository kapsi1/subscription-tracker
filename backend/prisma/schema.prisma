generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String                  @id @default(uuid())
  email                       String                  @unique
  passwordHash                String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  defaultReminderDays         Int                     @default(3)
  defaultReminderEnabled      Boolean                 @default(false)
  lastBudgetAlertSentAt       DateTime?
  monthlyBudget               Decimal?
  language                    String                  @default("en")
  accentColor                 String                  @default("Indigo")
  dailyDigest                 Boolean                 @default(false)
  emailNotifications          Boolean                 @default(false)
  theme                       String                  @default("system")
  previousWeekReport          Boolean                 @default(false)
  nextWeekReport              Boolean                 @default(false)
  googleId                    String?                 @unique
  name                        String?
  dashboardSortBy             String                  @default("date")
  dashboardSortOrder          String                  @default("asc")
  showPaidPayments            Boolean                 @default(true)
  currency                    String                  @default("USD")
  avatarUrl                   String?
  isVerified                  Boolean                 @default(false)
  verificationToken           String?                 @unique
  verificationTokenExpiresAt  DateTime?
  passwordResetToken          String?                 @unique
  passwordResetTokenExpiresAt DateTime?
  recentAccentColors          String[]
  hasSeenManageHint           Boolean                 @default(false)
  categories                  Category[]
  defaultReminders            UserDefaultReminder[]
  paymentHistory              PaymentHistory[]
  pushSubscriptions           PushSubscription[]
  subscriptions               Subscription[]
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  order     Int      @default(0)
  icon      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Subscription {
  id                            String           @id @default(uuid())
  userId                        String
  name                          String
  amount                        Decimal
  currency                      String
  billingCycle                  BillingCycle
  intervalDays                  Int?
  nextBillingDate               DateTime
  category                      String
  isActive                      Boolean          @default(true)
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt
  reminderDays                  Int              @default(3)
  reminderEnabled               Boolean          @default(false)
  billingDays                   Int[]            @default([])
  billingMonthShortageDirection String           @default("before")
  billingMonthShortageOffset    Int              @default(1)
  alerts                        Alert[]
  payments                      PaymentHistory[]
  user                          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextBillingDate])
  @@index([userId, isActive])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Alert {
  id             String       @id @default(uuid())
  subscriptionId String
  type           AlertType
  daysBefore     Int
  unit           ReminderUnit @default(days)
  isEnabled      Boolean      @default(true)
  lastSentAt     DateTime?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model UserDefaultReminder {
  id     String       @id @default(uuid())
  userId String
  type   AlertType
  value  Int
  unit   ReminderUnit @default(days)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PaymentHistory {
  id               String        @id @default(uuid())
  subscriptionId   String?
  amount           Decimal
  currency         String
  paidAt           DateTime      @default(now())
  subscriptionName String
  userId           String
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([paidAt])
  @@index([userId])
  @@index([userId, paidAt])
}

enum BillingCycle {
  weekly
  monthly
  yearly
  custom
}

enum AlertType {
  email
  webpush
}

enum ReminderUnit {
  minutes
  hours
  days
}
