generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String?
  passwordHash String?
  googleId     String?        @unique
  language     String         @default("en")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscriptions Subscription[]
  defaultReminderEnabled Boolean @default(true)
  defaultReminderDays    Int     @default(3)
  monthlyBudget          Decimal?
  lastBudgetAlertSentAt  DateTime?
  pushSubscriptions      PushSubscription[]
  theme                  String         @default("system")
  accentColor            String         @default("Indigo")
  emailNotifications     Boolean        @default(true)
  webhookEnabled         Boolean        @default(false)
  webhookUrl             String?
  webhookSecret          String?
  dailyDigest            Boolean        @default(false)
  weeklyReport           Boolean        @default(true)
  dashboardSortBy        String         @default("date")
  dashboardSortOrder     String         @default("asc")
  showPaidPayments       Boolean        @default(true)
  currency               String         @default("USD")
  avatarUrl              String?
}

enum BillingCycle {
  monthly
  yearly
  custom
}

model Subscription {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  name            String
  amount          Decimal
  currency        String
  billingCycle    BillingCycle
  intervalDays    Int?
  nextBillingDate DateTime
  category        String
  isActive        Boolean        @default(true)
  reminderEnabled Boolean        @default(true)
  reminderDays    Int            @default(3)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  alerts          Alert[]
  payments        PaymentHistory[]

  @@index([userId])
}

enum AlertType {
  email
  webhook
  webpush
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Alert {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  type           AlertType
  daysBefore     Int
  isEnabled      Boolean      @default(true)
  webhookUrl     String?
  webhookSecret  String?

  @@index([subscriptionId])
}

model PaymentHistory {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  amount         Decimal
  currency       String
  paidAt         DateTime     @default(now())

  @@index([subscriptionId])
}
