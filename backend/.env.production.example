# Production environment template
# Copy values into your deployment platform (e.g. Koyeb Environment Variables).
# Do not commit real secrets.

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=public

# Redis
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# Backend
NODE_ENV=production
PORT=3001
JWT_SECRET=<strong-random-jwt-secret>
JWT_EXPIRES_IN=1h

# Frontend
NEXT_PUBLIC_API_URL=https://<your-api-domain>

# SMTP (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your_brevo_smtp_login>
SMTP_PASS=<your_brevo_smtp_key>
SMTP_FROM="Subscription Tracker" <you@yourdomain.com>

# Optional: Webhook encryption key (set a strong random value in production)
WEBHOOK_SECRET_KEY=<strong-random-webhook-secret>
