{
  "name": "subscription-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "cd packages/shared && pnpm build && cd ../..",
    "build:backend": "cd backend && pnpm build && cd ../..",
    "build:frontend": "cd frontend && pnpm build && cd ../..",
    "dev": "pnpm --filter @subscription-tracker/shared build && concurrently -n \"shared,backend,frontend\" -c \"magenta,blue,green\" \"pnpm --filter @subscription-tracker/shared dev\" \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:shared": "pnpm --filter @subscription-tracker/shared dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "Kamil Kapsiak",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "concurrently": "^9.2.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
