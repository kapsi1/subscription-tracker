{
  "name": "subscription-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @subscription-tracker/shared build && concurrently -n \"shared,backend,frontend\" -c \"magenta,blue,green\" \"pnpm --filter @subscription-tracker/shared dev\" \"pnpm --filter backend dev\" \"pnpm --filter next-app dev\"",
    "dev:shared": "pnpm --filter @subscription-tracker/shared dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter next-app dev",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "concurrently": "^9.2.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
